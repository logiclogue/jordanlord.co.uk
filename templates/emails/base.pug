doctype html
html(lang="en")
    head
        meta(charset="utf-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        meta(name="x-apple-disable-message-reformatting")
        title!= subject
    body(style=`margin:0; padding:0; background-color:${theme.background}; color:${theme.foreground}; font-family:${theme.fontStack};`)
        if previewText
            div(style="display:none; max-height:0; overflow:hidden; opacity:0; mso-hide:all;")= previewText
        table(role="presentation", cellpadding="0", cellspacing="0", border="0", width="100%", style=`width:100%; border-collapse:collapse; background-color:${theme.background};`)
            tr
                td(align="center", style="padding:32px 16px;")
                    table(role="presentation", cellpadding="0", cellspacing="0", border="0", width="100%", style=`max-width:640px; width:100%; border-collapse:collapse; background-color:${theme.panel};`)
                        tr
                            td(style=`padding:20px 24px;`)
                                table(role="presentation", cellpadding="0", cellspacing="0", border="0", width="100%", style="width:100%; border-collapse:collapse;")
                                    tr
                                        td(style="font-size:28px; line-height:1.2; font-weight:bold;")
                                            a(href=siteurl, style=`color:${theme.foreground}; text-decoration:none;`) #{sitename}
                                        td(align="right", style=`font-size:12px; letter-spacing:1px; text-transform:uppercase; color:${theme.muted};`)!= eyebrow
                        tr
                            td(style="padding:28px 24px 8px 24px;")
                                h1(style=`margin:0 0 16px 0; font-size:28px; line-height:1.3; color:${theme.heading}; font-weight:bold;`)!= title
                                if intro
                                    p(style=`margin:0 0 16px 0; font-size:16px; line-height:1.7; color:${theme.foreground};`) #{intro}
                        tr
                            td(style="padding:0 24px 8px 24px;")
                                block content
                        if ctaUrl && ctaLabel
                            tr
                                td(style="padding:8px 24px 24px 24px;")
                                    table(role="presentation", cellpadding="0", cellspacing="0", border="0")
                                        tr
                                            td(style=`background-color:${theme.accent}; border:1px solid ${theme.accent};`)
                                                a(href!=ctaUrl, style=`display:inline-block; padding:14px 20px; color:${theme.background}; text-decoration:none; font-size:16px; line-height:1.2; font-weight:bold;`) #{ctaLabel}
                        if secondaryText
                            tr
                                td(style=`padding:0 24px 24px 24px; font-size:13px; line-height:1.7; color:${theme.muted};`)!= secondaryText
                        tr
                            td(style=`padding:20px 24px 24px 24px; font-size:13px; line-height:1.7; color:${theme.muted};`)
                                p(style="margin:0;") Copyright &#169; #{year} #{sitename}
        if trackingHtml
            != trackingHtml
